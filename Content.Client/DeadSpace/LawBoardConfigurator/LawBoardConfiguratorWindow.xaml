<controls:FancyWindow
    xmlns="https://spacestation14.io"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:customControls="clr-namespace:Content.Client.Administration.UI.CustomControls"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    Title="{Loc silicon-law-ui-title}"
    MinSize="680 460"
    SetSize="920 620"
>
    <BoxContainer Orientation="Vertical" Margin="8" HorizontalExpand="True" VerticalExpand="True">
        <PanelContainer Margin="0 0 0 8">
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BackgroundColor="#241538" />
            </PanelContainer.PanelOverride>
            <BoxContainer Orientation="Vertical" Margin="12 8 12 8" HorizontalAlignment="Center">
                <Label Text="{Loc law-board-configurator-ui-title}" />
            </BoxContainer>
        </PanelContainer>

        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="4" Margin="0 0 0 8">
            <Button Name="EjectBoardButton" Text="{Loc verb-categories-eject}" MaxSize="230 64" StyleClasses="OpenRight" />
            <Control HorizontalExpand="True"/>
            <Button Name="NewLawButton" Text="{Loc silicon-law-ui-new-law}" MaxSize="230 64" StyleClasses="OpenRight" />
            <Button Name="SaveButton" Text="{Loc silicon-law-ui-save}" MaxSize="230 64" StyleClasses="OpenLeft" />
        </BoxContainer>

        <customControls:HSeparator StyleClasses="LowDivider" Margin="0 0 0 8"/>

        <PanelContainer Name="NoBoardPanel" VerticalExpand="True" Visible="False">
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BackgroundColor="#1A1426" />
            </PanelContainer.PanelOverride>
            <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True" HorizontalAlignment="Center" VerticalAlignment="Center" SeparationOverride="4">
                <Label Text="{Loc law-board-configurator-requires-board}" />
            </BoxContainer>
        </PanelContainer>

        <BoxContainer Name="BoardEditorContainer" Orientation="Vertical" VerticalExpand="True">
            <PanelContainer Margin="0 0 0 8">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#201730" />
                </PanelContainer.PanelOverride>
                <BoxContainer Orientation="Horizontal" Margin="8 6 8 6">
                    <Label Text="{Loc law-board-configurator-ui-board-name}" Margin="0 3 8 0" />
                    <LineEdit Name="BoardNameInput" HorizontalExpand="True" />
                </BoxContainer>
            </PanelContainer>

            <PanelContainer VerticalExpand="True">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#1A1426" />
                </PanelContainer.PanelOverride>
                <ScrollContainer VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False" ReturnMeasure="True" Margin="6">
                    <BoxContainer Orientation="Vertical" Name="LawContainer" HorizontalExpand="True" />
                </ScrollContainer>
            </PanelContainer>
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
