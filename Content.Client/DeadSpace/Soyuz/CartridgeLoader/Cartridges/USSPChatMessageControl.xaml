<Control xmlns="https://spacestation14.io"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Content.Client.DeadSpace.Soyuz.CartridgeLoader.Cartridges.USSPChatMessageControl">
    <BoxContainer Name="MessageContainer" Orientation="Horizontal" HorizontalExpand="True" Margin="2">
        <PanelContainer Name="MessageBubble" HorizontalExpand="False">
            <BoxContainer Name="MessageContent" Orientation="Vertical" MinWidth="100" Margin="0">
                <BoxContainer Name="HeaderContainer" Orientation="Horizontal" HorizontalExpand="True">
                    <Label Name="SenderName" StyleClasses="LabelSubText" Margin="0 0 5 0"/>
                    <Label Name="TimeLabel" StyleClasses="LabelSubText"/>
                    <Control HorizontalExpand="True"/>
                </BoxContainer>
                <RichTextLabel Name="MessageText"/>
            </BoxContainer>
        </PanelContainer>
        <Control HorizontalExpand="True"/>
    </BoxContainer>
</Control>
