<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               x:Class="Content.Client.DeadSpace.Soyuz.CartridgeLoader.Cartridges.USSPChatJoinGroupPopup"
               Title="{Loc 'ussp-chat-ui-join-group-title'}"
               MinWidth="500">
    <BoxContainer Orientation="Vertical" Margin="4" HorizontalExpand="True">
        <Label Text="{Loc 'ussp-chat-ui-group-id'}" StyleClasses="LabelHeading"/>
        <LineEdit Name="GroupIdInput" PlaceHolder="{Loc 'ussp-chat-ui-group-id-placeholder'}" HorizontalExpand="True"/>
        <Label Name="ErrorLabel"
               StyleClasses="LabelSubText"
               Modulate="#ff8080"
               Visible="False"/>
        <BoxContainer Orientation="Horizontal" HorizontalAlignment="Right" HorizontalExpand="True" Margin="0 8 0 0">
            <Button Name="CancelButton" Text="{Loc 'ussp-chat-ui-cancel'}"/>
            <Button Name="JoinButton" Text="{Loc 'ussp-chat-ui-join'}"/>
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
