<cartridges:USSPChatUiFragment
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cartridges="clr-namespace:Content.Client.DeadSpace.Soyuz.CartridgeLoader.Cartridges;assembly=Content.Client"
    xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls;assembly=Content.Client"
    xmlns:customControls="clr-namespace:Content.Client.Administration.UI.CustomControls;assembly=Content.Client"
    x:Class="Content.Client.DeadSpace.Soyuz.CartridgeLoader.Cartridges.USSPChatUiFragment"
    Orientation="Vertical"
    HorizontalExpand="True"
    VerticalExpand="True"
    Margin="4">
    <BoxContainer Orientation="Horizontal" HorizontalExpand="True" VerticalExpand="False">
        <controls:StripeBack HorizontalExpand="True">
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True" VerticalAlignment="Center">
                <TextureRect StyleClasses="NTLogoDark" Stretch="KeepAspectCentered" SetSize="32 32" Margin="0 0 4 0"/>
                <Label Text="{Loc 'ussp-chat-ui-title'}" StyleClasses="LabelHeading" VerticalAlignment="Center"/>
                <Label Name="OwnIdLabel" StyleClasses="LabelSubText" VerticalAlignment="Center" Margin="4 0 0 0"/>
                <Control HorizontalExpand="True"/>
                <TextureButton Name="MuteChatButton" MaxSize="24 24" Margin="0 0 4 0"/>
                <CheckBox Name="VisibleInDiscoveryCheckBox" VerticalAlignment="Center" ToolTip="{Loc 'ussp-chat-ui-visible-in-discovery-tooltip'}"/>
                <TextureButton Name="FindContactsButton" MaxSize="24 24" ToolTip="{Loc 'ussp-chat-ui-discovery-tooltip'}"
                    TexturePath="/Textures/Interface/VerbIcons/refresh.svg.192dpi.png" VerticalAlignment="Center" Margin="4 0 0 0"/>
                <TextureButton Name="AddContactButton" MaxSize="24 24" ToolTip="{Loc 'ussp-chat-ui-add-contact-tooltip'}"
                    TexturePath="/Textures/Interface/VerbIcons/plus.svg.192dpi.png" VerticalAlignment="Center" Margin="4 0 0 0"/>
                <TextureButton Name="JoinGroupButton" MaxSize="24 24" ToolTip="{Loc 'ussp-chat-ui-join-group-tooltip'}"
                    TexturePath="/Textures/Interface/VerbIcons/in.svg.192dpi.png" VerticalAlignment="Center" Margin="4 0 0 0"/>
                <TextureButton Name="CreateGroupButton" MaxSize="24 24" ToolTip="{Loc 'ussp-chat-ui-create-group-tooltip'}"
                    TexturePath="/Textures/Interface/VerbIcons/group.svg.192dpi.png" VerticalAlignment="Center" Margin="4 0 0 0"/>
            </BoxContainer>
        </controls:StripeBack>
    </BoxContainer>
    <BoxContainer Orientation="Horizontal" HorizontalExpand="True" VerticalExpand="True">
        <PanelContainer StyleClasses="AngleRect" MinWidth="190" MaxWidth="240" VerticalExpand="True">
            <BoxContainer Orientation="Vertical" VerticalExpand="True" HorizontalExpand="True">
                <TabContainer Name="ChatTypeTabs" VerticalExpand="True">
                    <ScrollContainer VerticalExpand="True" HorizontalExpand="True">
                        <BoxContainer Name="ContactsContainer" Orientation="Vertical" HorizontalExpand="True"/>
                    </ScrollContainer>
                    <ScrollContainer VerticalExpand="True" HorizontalExpand="True">
                        <BoxContainer Name="GroupsContainer" Orientation="Vertical" HorizontalExpand="True"/>
                    </ScrollContainer>
                </TabContainer>
                <Label Name="NoContactsLabel" Text="{Loc 'ussp-chat-ui-no-contacts'}" StyleClasses="LabelSubText"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Visible="False"/>
                <Label Name="NoGroupsLabel" Text="{Loc 'ussp-chat-ui-no-groups'}" StyleClasses="LabelSubText"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Visible="False"/>
            </BoxContainer>
        </PanelContainer>
        <customControls:VSeparator StyleClasses="LowDivider"/>
        <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
            <PanelContainer Name="ChatHeaderPanel" StyleClasses="AngleRect" HorizontalExpand="True">
                <PanelContainer.PanelOverride>
                    <graphics:StyleBoxFlat />
                </PanelContainer.PanelOverride>
                <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 0 0 4">
                    <Label Name="ChatTitle" StyleClasses="LabelHeading" Margin="4 0 0 0" VerticalAlignment="Center" HorizontalExpand="True"/>
                    <TextureButton Name="LeaveChatButton" MaxSize="24 24" Margin="0 0 4 0" Visible="False" ToolTip="{Loc 'ussp-chat-ui-leave-chat-tooltip'}"
                        TexturePath="/Textures/Interface/VerbIcons/close.svg.192dpi.png"/>
                    <TextureButton Name="EraseChatButton" MaxSize="24 24" Margin="0 0 4 0" Visible="False" ToolTip="{Loc 'ussp-chat-ui-erase-chat-tooltip'}"
                        TexturePath="/Textures/Interface/eraser.svg.png"/>
                    <TextureButton Name="CloseChatButton" MaxSize="24 24" Visible="False" ToolTip="{Loc 'ussp-chat-ui-close-chat-tooltip'}"
                        TexturePath="/Textures/Interface/Nano/cross.svg.png"/>
                </BoxContainer>
            </PanelContainer>
            <PanelContainer StyleClasses="AngleRect" VerticalExpand="True">
                <ScrollContainer Name="MessagesScroll" HScrollEnabled="False" VerticalExpand="True" HorizontalExpand="True">
                    <BoxContainer Name="MessagesContainer" Orientation="Vertical" Margin="4"/>
                </ScrollContainer>
            </PanelContainer>
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 4 0 0">
                <LineEdit Name="MessageInput" HorizontalExpand="True" Editable="False"/>
                <Button Name="EmojiButton" Text=":)" MinSize="32 32" Disabled="True" ToolTip="{Loc 'ussp-chat-ui-emoji-tooltip'}" Margin="4 0 0 0"/>
                <Button Name="SendButton" Text=">" MinSize="32 32" Disabled="True" ToolTip="{Loc 'ussp-chat-ui-send-tooltip'}"/>
            </BoxContainer>
        </BoxContainer>
    </BoxContainer>
</cartridges:USSPChatUiFragment>
