<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               x:Class="Content.Client.DeadSpace.Soyuz.CartridgeLoader.Cartridges.USSPChatCreateGroupPopup"
               Title="{Loc 'ussp-chat-ui-create-group-title'}"
               MinWidth="500">
    <BoxContainer Orientation="Vertical" Margin="4" HorizontalExpand="True">
        <Label Text="{Loc 'ussp-chat-ui-group-name'}" StyleClasses="LabelHeading"/>
        <LineEdit Name="GroupNameInput" PlaceHolder="{Loc 'ussp-chat-ui-group-name-placeholder'}" HorizontalExpand="True"/>
        <BoxContainer Orientation="Horizontal" HorizontalAlignment="Right" HorizontalExpand="True" Margin="0 8 0 0">
            <Button Name="CancelButton" Text="{Loc 'ussp-chat-ui-cancel'}"/>
            <Button Name="CreateButton" Text="{Loc 'ussp-chat-ui-create'}"/>
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
