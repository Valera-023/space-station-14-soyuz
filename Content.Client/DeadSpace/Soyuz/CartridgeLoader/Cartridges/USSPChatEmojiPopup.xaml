<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               x:Class="Content.Client.DeadSpace.Soyuz.CartridgeLoader.Cartridges.USSPChatEmojiPopup"
               Title="{Loc 'ussp-chat-ui-emoji-title'}"
               MinWidth="300"
               MinHeight="500">
    <BoxContainer Orientation="Vertical" Margin="4" HorizontalExpand="True">
        <Label Text="{Loc 'ussp-chat-ui-emoji-select'}" StyleClasses="LabelHeading" Margin="0 0 0 4"/>
        <ScrollContainer VerticalExpand="True" HorizontalExpand="True">
            <GridContainer Name="EmojiContainer" Columns="4" HorizontalExpand="True" VerticalExpand="False"/>
        </ScrollContainer>
    </BoxContainer>
</DefaultWindow>
