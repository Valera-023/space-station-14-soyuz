<DefaultWindow
    xmlns="https://spacestation14.io">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
        <Label Name="TargetLabel" HorizontalExpand="True" />
        <Label Text="{Loc 'admin-toy-name-label'}" HorizontalExpand="True" />
        <LineEdit Name="NameEdit" PlaceHolder="{Loc 'admin-toy-name-placeholder'}" HorizontalExpand="True" />
        <Label Text="{Loc 'admin-toy-description-label'}" HorizontalExpand="True" />
        <TextEdit Name="DescriptionEdit" MinHeight="90" HorizontalExpand="True" />
        <Label Text="{Loc 'admin-toy-tts-label'}" HorizontalExpand="True" />
        <OptionButton Name="TtsSelector" HorizontalExpand="True" />
        <LineEdit Name="SearchBar" PlaceHolder="{Loc 'admin-toy-search-placeholder'}" HorizontalExpand="True" />
        <ItemList Name="ToyList" SelectMode="Single" VerticalExpand="True" />
        <Button Name="ConfirmButton" HorizontalExpand="True" />
    </BoxContainer>
</DefaultWindow>
